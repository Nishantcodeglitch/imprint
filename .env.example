# ──────── IMPRINT Environment Variables ────────

# Server
PORT=3000
NODE_ENV=development

# Session (generate a random string for production)
SESSION_SECRET=

# Admin Credentials
# Generate password hash: node scripts/hash-password.js yourpassword
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# CORS (comma-separated for multiple origins)
ALLOWED_ORIGIN=http://localhost:3000
